{
  "name": "blog-backend",
  "version": "1.0.0",
  "main": "run_server.js",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "start": "node ./run_server.js",
    "dev": "nodemon ./run_server.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": true,
    "testTimeout": 15000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "connection/blockchain/**/*.js",
      "modules/**/*.js",
      "!**/node_modules/**",
      "!**/*.test.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^3.0.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
